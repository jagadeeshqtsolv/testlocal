{
  "id": "12173bdd-fb8e-4f41-a0f1-a655d30641c3",
  "testPlanId": "7da44c7a-09f8-4989-8071-713bfccb2ca6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article",
  "case": {
    "id": "12173bdd-fb8e-4f41-a0f1-a655d30641c3",
    "title": "Save article from Featured and open My Saved News via toast link",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "scrollIntoView",
        "targetDescription": "Featured News section",
        "screenName": "HomePage",
        "pageObjectMethod": "scrollFeaturedIntoView"
      },
      {
        "id": "s3",
        "action": "assertVisible",
        "targetDescription": "Any bookmark icon on a Featured news card",
        "screenName": "HomePage",
        "pageObjectMethod": "expectBookmark2Visible"
      },
      {
        "id": "s4",
        "action": "tap",
        "targetDescription": "Tap bookmark to save the article",
        "screenName": "HomePage",
        "pageObjectMethod": "clickBookmark2"
      },
      {
        "id": "s5",
        "action": "assertContainsText",
        "targetDescription": "Toast confirmation message",
        "locatorHint": "[role='alert']",
        "assertion": "News saved successfully!, View saved news under Profile"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Toast action: View saved news under Profile",
        "locatorHint": "text=View saved news under Profile"
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "My Saved News page heading or indicator",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s8",
        "action": "assertCountGreaterThan",
        "targetDescription": "Saved news list has at least 1 item",
        "locatorHint": "[data-testid='saved-news-list'] [data-testid='saved-news-item']"
      }
    ],
    "tags": [
      "@smoke",
      "@e2e",
      "@regression",
      "@demo"
    ]
  }
}
