{
  "id": "1f5d0cbd-2b99-4fe0-a6fa-ee7094d63b35",
  "testPlanId": "7da44c7a-09f8-4989-8071-713bfccb2ca6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article",
  "case": {
    "id": "1f5d0cbd-2b99-4fe0-a6fa-ee7094d63b35",
    "title": "Unsave from My Saved News removes the item immediately",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Open Profile menu",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickProfile"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Go to My Saved News",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "s4",
        "action": "assertVisible",
        "targetDescription": "My Saved News page displayed",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s5",
        "action": "assertCountGreaterThan",
        "targetDescription": "Ensure at least one saved item exists",
        "locatorHint": "[data-testid='saved-news-list'] [data-testid='saved-news-item']"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Unsave the first saved item",
        "locatorHint": "[data-testid='saved-news-item']:nth-child(1) [data-testid='bookmark']"
      },
      {
        "id": "s7",
        "action": "wait",
        "targetDescription": "Wait for list to update",
        "value": "1000"
      },
      {
        "id": "s8",
        "action": "assertHidden",
        "targetDescription": "First saved item bookmark icon no longer present (item removed)",
        "locatorHint": "[data-testid='saved-news-item']:nth-child(1) [data-testid='bookmark'][aria-pressed='true']"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}
