{
  "id": "d89ce9d9-a4a9-40c8-be4e-0480dc9d8df1",
  "testPlanId": "d30b6b32-f3b5-46b8-9a82-33c56a5141b6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article — Smoke",
  "case": {
    "id": "d89ce9d9-a4a9-40c8-be4e-0480dc9d8df1",
    "title": "Save a Latest News article and navigate via toast link to My Saved News",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "S1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "S2",
        "action": "scrollIntoView",
        "targetDescription": "Scroll to Latest News title",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "scrollLatestNewsTitleIntoView"
      },
      {
        "id": "S3",
        "action": "assertVisible",
        "targetDescription": "Latest News section is visible",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "expectLatestNewsTitleVisible"
      },
      {
        "id": "S4",
        "action": "assertVisible",
        "targetDescription": "Bookmark (Save) icon is visible on a Latest News card",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "expectSaveNewsVisible"
      },
      {
        "id": "S5",
        "action": "tap",
        "targetDescription": "Tap Save on a Latest News card",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "clickSaveNews"
      },
      {
        "id": "S6",
        "action": "waitForVisible",
        "targetDescription": "Wait for success toast",
        "locatorHint": "[role=alert]"
      },
      {
        "id": "S7",
        "action": "tap",
        "targetDescription": "Follow toast link to View saved news under Profile",
        "locatorHint": "text=View saved news under Profile"
      },
      {
        "id": "S8",
        "action": "assertVisible",
        "targetDescription": "My Saved News page is visible",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
