{
  "id": "78a301b2-1a78-480f-8ebb-22bf064db76b",
  "testPlanId": "75e0613c-e1b7-44b2-bf98-1d3475159907",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article - Smoke",
  "case": {
    "id": "78a301b2-1a78-480f-8ebb-22bf064db76b",
    "title": "Saved items persist for the user across navigation cycles",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons Home",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "scrollIntoView",
        "targetDescription": "Scroll to Featured section",
        "screenName": "HomePage",
        "pageObjectMethod": "scrollFeaturedIntoView"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Save a Featured article to ensure saved state exists",
        "screenName": "HomePage",
        "pageObjectMethod": "clickBookmark2"
      },
      {
        "id": "s4",
        "action": "assertContainsText",
        "targetDescription": "Verify save success toast appears",
        "locatorHint": "div[role='status']",
        "assertion": "News saved successfully!, View saved news under Profile"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Open Profile menu",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickProfile"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Open My Saved News",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "Verify My Saved News page is displayed",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s8",
        "action": "assertCountGreaterThan",
        "targetDescription": "Verify Saved list has at least one saved article card",
        "locatorHint": "[data-testid='saved-card']"
      },
      {
        "id": "s9",
        "action": "openUrl",
        "targetDescription": "Navigate away to Home",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s10",
        "action": "tap",
        "targetDescription": "Open Profile menu again",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickProfile"
      },
      {
        "id": "s11",
        "action": "tap",
        "targetDescription": "Reopen My Saved News",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "s12",
        "action": "assertVisible",
        "targetDescription": "Verify My Saved News page is displayed",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s13",
        "action": "assertCountGreaterThan",
        "targetDescription": "Verify Saved list still has at least one saved article (persistence)",
        "locatorHint": "[data-testid='saved-card']"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
