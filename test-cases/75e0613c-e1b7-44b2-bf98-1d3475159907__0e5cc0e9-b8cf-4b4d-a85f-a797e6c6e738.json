{
  "id": "0e5cc0e9-b8cf-4b4d-a85f-a797e6c6e738",
  "testPlanId": "75e0613c-e1b7-44b2-bf98-1d3475159907",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article - Smoke",
  "case": {
    "id": "0e5cc0e9-b8cf-4b4d-a85f-a797e6c6e738",
    "title": "Save Featured article via bookmark icon and open Saved News from toast",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons Home",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "scrollIntoView",
        "targetDescription": "Scroll to Featured section",
        "screenName": "HomePage",
        "pageObjectMethod": "scrollFeaturedIntoView"
      },
      {
        "id": "s3",
        "action": "assertVisible",
        "targetDescription": "Verify Featured section is visible",
        "screenName": "HomePage",
        "pageObjectMethod": "expectFeaturedVisible"
      },
      {
        "id": "s4",
        "action": "assertVisible",
        "targetDescription": "Verify bookmark icon is visible on a Featured article card",
        "screenName": "HomePage",
        "pageObjectMethod": "expectBookmark2Visible"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Tap bookmark icon on a Featured article card to Save",
        "screenName": "HomePage",
        "pageObjectMethod": "clickBookmark2"
      },
      {
        "id": "s6",
        "action": "assertContainsText",
        "targetDescription": "Verify success toast appears with Save confirmation and navigation hint",
        "locatorHint": "div[role='status']",
        "assertion": "News saved successfully!, View saved news under Profile"
      },
      {
        "id": "s7",
        "action": "assertChecked",
        "targetDescription": "Verify bookmark icon indicates Saved state (filled/active)",
        "screenName": "HomePage",
        "pageObjectMethod": "expectBookmark2Checked"
      },
      {
        "id": "s8",
        "action": "tap",
        "targetDescription": "Open 'View saved news under Profile' from toast",
        "locatorHint": "div[role='status'] a:has-text(\"View saved news under Profile\")"
      },
      {
        "id": "s9",
        "action": "assertVisible",
        "targetDescription": "Verify My Saved News page is displayed",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s10",
        "action": "assertCountGreaterThan",
        "targetDescription": "Verify Saved list has at least one saved article card",
        "locatorHint": "[data-testid='saved-card']"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
