{
  "id": "be0d52e6-7fec-4685-9b52-22583c4624f5",
  "testPlanId": "7da44c7a-09f8-4989-8071-713bfccb2ca6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article",
  "case": {
    "id": "be0d52e6-7fec-4685-9b52-22583c4624f5",
    "title": "Saved items display in reverse chronological order (latest saved on top)",
    "priority": "P2",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "scrollIntoView",
        "targetDescription": "Featured News section",
        "screenName": "HomePage",
        "pageObjectMethod": "scrollFeaturedIntoView"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Save first Featured article (A)",
        "locatorHint": "[data-testid='featured-news'] [data-testid='news-card']:nth-child(1) [data-testid='bookmark']"
      },
      {
        "id": "s4",
        "action": "tap",
        "targetDescription": "Save second Featured article (B)",
        "locatorHint": "[data-testid='featured-news'] [data-testid='news-card']:nth-child(2) [data-testid='bookmark']"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Open Profile menu",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickProfile"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Go to My Saved News",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "My Saved News page displayed",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s8",
        "action": "assertContainsText",
        "targetDescription": "Top item in saved list equals title of article B (most recently saved)",
        "locatorHint": "[data-testid='saved-news-item']:nth-child(1)",
        "assertion": "{{Title of second saved article (B)}}"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}
