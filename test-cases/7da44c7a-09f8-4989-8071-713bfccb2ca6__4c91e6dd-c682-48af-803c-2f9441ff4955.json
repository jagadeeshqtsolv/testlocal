{
  "id": "4c91e6dd-c682-48af-803c-2f9441ff4955",
  "testPlanId": "7da44c7a-09f8-4989-8071-713bfccb2ca6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article",
  "case": {
    "id": "4c91e6dd-c682-48af-803c-2f9441ff4955",
    "title": "Archived/deleted article is removed automatically from My Saved News",
    "priority": "P2",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "scrollIntoView",
        "targetDescription": "Latest News section",
        "locatorHint": "[data-testid='latest-news']"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Save a specific Latest article with known id 'latest-1'",
        "locatorHint": "[data-testid='latest-news'] [data-testid='news-card'][data-article-id='latest-1'] [data-testid='bookmark']"
      },
      {
        "id": "s4",
        "action": "assertContainsText",
        "targetDescription": "Toast confirmation",
        "locatorHint": "[role='alert']",
        "assertion": "News saved successfully!"
      },
      {
        "id": "s5",
        "action": "openUrl",
        "targetDescription": "Test API to archive the article latest-1",
        "value": "https://commons-qa.util.ukg.com/test-api/archive?articleId=latest-1"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Open Profile menu",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickProfile"
      },
      {
        "id": "s7",
        "action": "tap",
        "targetDescription": "Go to My Saved News",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "s8",
        "action": "wait",
        "targetDescription": "Wait for sync/removal",
        "value": "2000"
      },
      {
        "id": "s9",
        "action": "assertHidden",
        "targetDescription": "Archived article latest-1 no longer appears in saved list",
        "locatorHint": "[data-testid='saved-news-item'][data-article-id='latest-1']"
      }
    ],
    "tags": [
      "@functional",
      "@e2e",
      "@regression"
    ]
  }
}
