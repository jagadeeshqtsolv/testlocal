{
  "id": "a35cc62e-1d7d-415d-8f61-46bf56c3534b",
  "testPlanId": "7da44c7a-09f8-4989-8071-713bfccb2ca6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article",
  "case": {
    "id": "a35cc62e-1d7d-415d-8f61-46bf56c3534b",
    "title": "Save article from Latest News and verify it appears in My Saved News",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "scrollIntoView",
        "targetDescription": "Latest News section",
        "locatorHint": "[data-testid='latest-news']"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Tap bookmark on first Latest news card",
        "locatorHint": "[data-testid='latest-news'] [data-testid='news-card']:nth-child(1) [data-testid='bookmark']"
      },
      {
        "id": "s4",
        "action": "assertContainsText",
        "targetDescription": "Toast confirmation appears",
        "locatorHint": "[role='alert']",
        "assertion": "News saved successfully!"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Open Profile menu",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickProfile"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Go to My Saved News",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "My Saved News page displayed",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s8",
        "action": "assertCountGreaterThan",
        "targetDescription": "Saved news list shows at least one item",
        "locatorHint": "[data-testid='saved-news-list'] [data-testid='saved-news-item']"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}
