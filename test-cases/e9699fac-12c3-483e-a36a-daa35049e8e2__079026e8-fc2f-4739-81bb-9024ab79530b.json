{
  "id": "079026e8-fc2f-4739-81bb-9024ab79530b",
  "testPlanId": "e9699fac-12c3-483e-a36a-daa35049e8e2",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article - Smoke",
  "case": {
    "id": "079026e8-fc2f-4739-81bb-9024ab79530b",
    "title": "If an article is deleted or archived, it disappears from My Saved News",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to UKG Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "step2",
        "action": "scrollIntoView",
        "targetDescription": "Scroll to Featured News section",
        "locatorHint": "[data-testid='featured-news-section']"
      },
      {
        "id": "step3",
        "action": "tap",
        "targetDescription": "Tap bookmark icon on a Featured News article",
        "locatorHint": "[data-testid='featured-news-card'] [data-testid='bookmark-icon']"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click 'View saved news under Profile' in toast",
        "locatorHint": "[data-testid='view-saved-news-toast-link']"
      },
      {
        "id": "step5",
        "action": "assertVisible",
        "targetDescription": "Saved article is listed in My Saved News",
        "locatorHint": "[data-testid='saved-news-card']"
      },
      {
        "id": "step6",
        "action": "wait",
        "targetDescription": "Simulate article deletion or archival in backend"
      },
      {
        "id": "step7",
        "action": "assertHidden",
        "targetDescription": "Deleted/archived article is removed from My Saved News",
        "locatorHint": "[data-testid='saved-news-card']"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
