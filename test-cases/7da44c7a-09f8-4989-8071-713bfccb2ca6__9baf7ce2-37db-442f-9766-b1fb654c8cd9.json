{
  "id": "9baf7ce2-37db-442f-9766-b1fb654c8cd9",
  "testPlanId": "7da44c7a-09f8-4989-8071-713bfccb2ca6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article",
  "case": {
    "id": "9baf7ce2-37db-442f-9766-b1fb654c8cd9",
    "title": "Save/Unsave toggle on Featured card and persistence after reload",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "scrollIntoView",
        "targetDescription": "Featured News section",
        "screenName": "HomePage",
        "pageObjectMethod": "scrollFeaturedIntoView"
      },
      {
        "id": "s3",
        "action": "assertUnchecked",
        "targetDescription": "Bookmark icon is unfilled before saving",
        "screenName": "HomePage",
        "pageObjectMethod": "expectBookmark2Unchecked"
      },
      {
        "id": "s4",
        "action": "tap",
        "targetDescription": "Tap bookmark to save",
        "screenName": "HomePage",
        "pageObjectMethod": "clickBookmark2"
      },
      {
        "id": "s5",
        "action": "assertChecked",
        "targetDescription": "Bookmark icon becomes filled",
        "screenName": "HomePage",
        "pageObjectMethod": "expectBookmark2Checked"
      },
      {
        "id": "s6",
        "action": "openUrl",
        "targetDescription": "Reload page to verify persistence",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s7",
        "action": "scrollIntoView",
        "targetDescription": "Featured News section",
        "screenName": "HomePage",
        "pageObjectMethod": "scrollFeaturedIntoView"
      },
      {
        "id": "s8",
        "action": "assertChecked",
        "targetDescription": "Bookmark icon remains filled after reload",
        "screenName": "HomePage",
        "pageObjectMethod": "expectBookmark2Checked"
      },
      {
        "id": "s9",
        "action": "tap",
        "targetDescription": "Tap bookmark to unsave",
        "screenName": "HomePage",
        "pageObjectMethod": "clickBookmark2"
      },
      {
        "id": "s10",
        "action": "assertUnchecked",
        "targetDescription": "Bookmark icon becomes unfilled after unsave",
        "screenName": "HomePage",
        "pageObjectMethod": "expectBookmark2Unchecked"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}
