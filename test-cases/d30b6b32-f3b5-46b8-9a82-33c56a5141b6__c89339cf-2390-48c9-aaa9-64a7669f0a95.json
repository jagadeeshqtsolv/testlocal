{
  "id": "c89339cf-2390-48c9-aaa9-64a7669f0a95",
  "testPlanId": "d30b6b32-f3b5-46b8-9a82-33c56a5141b6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article — Smoke",
  "case": {
    "id": "c89339cf-2390-48c9-aaa9-64a7669f0a95",
    "title": "Save a Featured News article and view it in My Saved News",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "S1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "S2",
        "action": "assertVisible",
        "targetDescription": "Featured section is visible",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "expectFeaturedVisible"
      },
      {
        "id": "S3",
        "action": "assertVisible",
        "targetDescription": "Bookmark (Save) icon is visible on a Featured article card",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "expectSaveNewsVisible"
      },
      {
        "id": "S4",
        "action": "tap",
        "targetDescription": "Tap Save on a Featured article card",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "clickSaveNews"
      },
      {
        "id": "S5",
        "action": "waitForVisible",
        "targetDescription": "Wait for success toast",
        "locatorHint": "[role=alert]"
      },
      {
        "id": "S6",
        "action": "assertContainsText",
        "targetDescription": "Toast confirms article saved",
        "locatorHint": "[role=alert]",
        "assertion": "News saved successfully!"
      },
      {
        "id": "S7",
        "action": "assertContainsText",
        "targetDescription": "Toast includes link to saved news under Profile",
        "locatorHint": "[role=alert]",
        "assertion": "View saved news under Profile"
      },
      {
        "id": "S8",
        "action": "tap",
        "targetDescription": "Open My Saved News from profile",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "S9",
        "action": "assertVisible",
        "targetDescription": "My Saved News page is visible",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "S10",
        "action": "assertCountGreaterThan",
        "targetDescription": "At least one saved news card is listed",
        "locatorHint": "css=.saved-news-card"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
