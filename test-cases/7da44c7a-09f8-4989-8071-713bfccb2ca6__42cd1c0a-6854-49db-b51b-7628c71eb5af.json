{
  "id": "42cd1c0a-6854-49db-b51b-7628c71eb5af",
  "testPlanId": "7da44c7a-09f8-4989-8071-713bfccb2ca6",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article",
  "case": {
    "id": "42cd1c0a-6854-49db-b51b-7628c71eb5af",
    "title": "Open a saved news item and verify article page loads",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Open Profile menu",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickProfile"
      },
      {
        "id": "s3",
        "action": "tap",
        "targetDescription": "Go to My Saved News",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "s4",
        "action": "assertVisible",
        "targetDescription": "My Saved News page displayed",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Open first saved news item",
        "locatorHint": "[data-testid='saved-news-item']:nth-child(1) a"
      },
      {
        "id": "s6",
        "action": "switchToNewTab",
        "targetDescription": "Switch to article tab"
      },
      {
        "id": "s7",
        "action": "waitForVisible",
        "targetDescription": "Article content appears",
        "locatorHint": "body",
        "value": "5000"
      },
      {
        "id": "s8",
        "action": "assertVisible",
        "targetDescription": "Article body is visible",
        "locatorHint": "body"
      }
    ],
    "tags": [
      "@functional",
      "@e2e",
      "@regression"
    ]
  }
}
