  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article - Smoke",
  "case": {
    "id": "d69bf769-3fb5-4a99-b934-518d80e5bb16",
    "title": "Saved articles are private to the user",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to UKG Commons QA as User A",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "step2",
        "action": "scrollIntoView",
        "targetDescription": "Scroll to Featured News section",
        "locatorHint": "[data-testid='featured-news-section']"
      },
      {
        "id": "step3",
        "action": "tap",
        "targetDescription": "Tap bookmark icon on a Featured News article",
        "locatorHint": "[data-testid='featured-news-card'] [data-testid='bookmark-icon']"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click 'View saved news under Profile' in toast",
        "locatorHint": "[data-testid='view-saved-news-toast-link']"
      },
      {
        "id": "step5",
        "action": "assertVisible",
        "targetDescription": "Saved article is listed in My Saved News for User A",
        "locatorHint": "[data-testid='saved-news-card']"
      },
      {
        "id": "step6",
        "action": "openUrl",
        "targetDescription": "Log in as User B and navigate to My Saved News",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "step7",
        "action": "tap",
        "targetDescription": "Open My Saved News from profile",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "step8",
        "action": "assertHidden",
        "targetDescription": "Saved article from User A is not visible in User B's My Saved News",
        "locatorHint": "[data-testid='saved-news-card']"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
