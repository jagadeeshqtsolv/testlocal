{
  "id": "39ba8ad6-2bb5-4600-afc9-f9d7428cbee6",
  "testPlanId": "75e0613c-e1b7-44b2-bf98-1d3475159907",
  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article - Smoke",
  "case": {
    "id": "39ba8ad6-2bb5-4600-afc9-f9d7428cbee6",
    "title": "Save Latest News article and access Saved News via Profile menu",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons Home",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "s2",
        "action": "scrollIntoView",
        "targetDescription": "Scroll to Latest News section",
        "locatorHint": "section[aria-label='Latest News']"
      },
      {
        "id": "s3",
        "action": "assertVisible",
        "targetDescription": "Verify Latest News section is visible",
        "locatorHint": "section[aria-label='Latest News']"
      },
      {
        "id": "s4",
        "action": "assertVisible",
        "targetDescription": "Verify a Save (bookmark) icon is present on a Latest News card",
        "locatorHint": "section[aria-label='Latest News'] .news-card:first-of-type button[aria-label='Save']"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Tap Save icon on first Latest News card",
        "locatorHint": "section[aria-label='Latest News'] .news-card:first-of-type button[aria-label='Save']"
      },
      {
        "id": "s6",
        "action": "assertContainsText",
        "targetDescription": "Verify success toast appears",
        "locatorHint": "div[role='status']",
        "assertion": "News saved successfully!, View saved news under Profile"
      },
      {
        "id": "s7",
        "action": "tap",
        "targetDescription": "Open Profile menu",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickProfile"
      },
      {
        "id": "s8",
        "action": "tap",
        "targetDescription": "Open My Saved News",
        "screenName": "ProfilePage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "s9",
        "action": "assertVisible",
        "targetDescription": "Verify My Saved News page is displayed",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "s10",
        "action": "assertCountGreaterThan",
        "targetDescription": "Verify Saved list has at least one saved article card",
        "locatorHint": "[data-testid='saved-card']"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
