  "requirementId": "eece6342-3ec9-42c9-a0b6-858405104039",
  "suiteName": "Save News Article — Smoke",
  "case": {
    "id": "835eaa73-f761-4624-8f00-74f21b239ab1",
    "title": "Unsaving removes the item immediately from My Saved News",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "S1",
        "action": "openUrl",
        "targetDescription": "Navigate to Commons QA",
        "value": "https://commons-qa.util.ukg.com/"
      },
      {
        "id": "S2",
        "action": "tap",
        "targetDescription": "Save any visible article to ensure at least one saved item exists",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "clickSaveNews"
      },
      {
        "id": "S3",
        "action": "tap",
        "targetDescription": "Open My Saved News from profile",
        "screenName": "UkgcommonsPage",
        "pageObjectMethod": "clickMySavedNews"
      },
      {
        "id": "S4",
        "action": "assertVisible",
        "targetDescription": "My Saved News page is visible",
        "screenName": "SavedNewsPage",
        "pageObjectMethod": "expectMySavedNewsVisible"
      },
      {
        "id": "S5",
        "action": "tap",
        "targetDescription": "Unsave the first saved item from the list",
        "locatorHint": "css=.saved-news-card:first-child [aria-label='Unsave']"
      },
      {
        "id": "S6",
        "action": "wait",
        "targetDescription": "Wait for removal animation/refresh"
      },
      {
        "id": "S7",
        "action": "assertVisible",
        "targetDescription": "Empty state shown after unsaving last item (or item removed instantly)",
        "locatorHint": "text=/No saved news/i"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
