{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "preserveSymlinks": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@support/*": ["./support/*"],
      "@pageobjects/*": ["./pageobjects/*"],
      "@api/*": ["./api/*"],
      "@testdata/*": ["./testdata/*"],
      "@utils/*": ["./utils/*"]
    }
  },
  "include": [
    "pageobjects/**/*.ts",
    "api/**/*.ts",
    "support/**/*.ts",
    "tests/**/*.ts",
    "utils/**/*.ts",
    "playwright.config.ts"
  ]
}
